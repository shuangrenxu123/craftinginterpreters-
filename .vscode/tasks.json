{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "hello-c: CMake Configure",
      "type": "shell",
      "command": "C:/msys64/ucrt64/bin/cmake.exe",
      "args": [
        "-S",
        "hello-c",
        "-B",
        "hello-c/build",
        "-G",
        "Ninja",
        "-DCMAKE_C_COMPILER=C:/msys64/ucrt64/bin/gcc.exe"
      ],
      "problemMatcher": []
    },
    {
      "label": "hello-c: CMake Build",
      "type": "shell",
      "command": "C:/msys64/ucrt64/bin/cmake.exe",
      "args": [
        "--build",
        "hello-c/build"
      ],
      "dependsOn": "hello-c: CMake Configure",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
